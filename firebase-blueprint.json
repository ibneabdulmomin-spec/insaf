{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users including shareholders and employees",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "shareholder", "employee"] },
        "disabled": { "type": "boolean", "default": false },
        "code": { "type": "string", "description": "Unique identification code" }
      },
      "required": ["uid", "email", "role"]
    },
    "ShareholderReport": {
      "title": "Shareholder Report",
      "description": "Monthly payment reports for shareholders",
      "type": "object",
      "properties": {
        "shareholderCode": { "type": "string" },
        "month": { "type": "string" },
        "amount": { "type": "number" },
        "premiumAmount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["shareholderCode", "month", "amount"]
    },
    "Notice": {
      "title": "Notice",
      "description": "Announcements for the organization",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean", "default": true }
      },
      "required": ["title", "content", "date"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "Images of social and organizational activities",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["url"]
    },
    "Task": {
      "title": "Task",
      "description": "Tasks for admins and employees",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assigneeId": { "type": "string" },
        "assigneeName": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["To Do", "In Progress", "Completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" }
      },
      "required": ["title", "assigneeId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/reports/{reportId}": {
      "schema": "ShareholderReport",
      "description": "Shareholder payment reports"
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Organization announcements"
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Activity images"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Admin and employee tasks"
    }
  }
}
