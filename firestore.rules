rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role (admin/shareholder/employee), code
    //
    // Collection: reports
    // Fields: shareholderCode, month, amount, premiumAmount, timestamp
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "ibne.abdul.momin@gmail.com" ||
         request.auth.token.email == "ibneabdulmomin@gmail.com" ||
         request.auth.token.email == "alinsaf34@gmail.com");
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated(); // Further filtered by code in app
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
